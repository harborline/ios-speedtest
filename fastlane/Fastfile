default_platform(:ios)

BUNDLE_ID     = "com.speedteststealth"
DEV_TEAM_ID   = "8SBK293L6F"   # Apple Development cert / project default
DIST_TEAM_ID  = "95W8G892Z4"   # Apple Distribution cert + provisioning profiles
KEY_PATH      = File.expand_path("../AuthKey_N3S3GACBN2.p8", __dir__)
KEY_ID        = "N3S3GACBN2"
ISSUER_ID     = "19f6fa40-e859-4234-a509-cb794faa464a"

platform :ios do

  before_all do
    app_store_connect_api_key(
      key_id:       KEY_ID,
      issuer_id:    ISSUER_ID,
      key_filepath: KEY_PATH,
      in_house:     false
    )
  end

  # ─── Ensure distribution cert is in keychain ────────────────────────────────
  lane :certs do
    get_certificates(
      team_id:     DIST_TEAM_ID,
      output_path: "/tmp/certs"
    )
  end

  # ─── Build ──────────────────────────────────────────────────────────────────
  lane :build do
    certs

    # Download & install App Store distribution provisioning profile
    sh("mkdir -p /tmp/profiles")
    get_provisioning_profile(
      app_identifier: BUNDLE_ID,
      team_id:        DIST_TEAM_ID,
      output_path:    "/tmp/profiles",
      filename:       "SpeedTestStealth_AppStore.mobileprovision"
    )
    profile_uuid = ENV["SIGH_UUID"]
    UI.message("Using provisioning profile UUID: #{profile_uuid}")

    current_build = begin
      latest_testflight_build_number(app_identifier: BUNDLE_ID).to_i
    rescue
      0
    end
    increment_build_number(
      xcodeproj:    "SpeedTest.xcodeproj",
      build_number: current_build + 1
    )

    gym(
      project:          "SpeedTest.xcodeproj",
      scheme:           "SpeedTest",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "SpeedTestStealth.ipa",
      clean:            true,
      xcargs:           "CODE_SIGN_STYLE=Manual " \
                        "DEVELOPMENT_TEAM=#{DIST_TEAM_ID} " \
                        "CODE_SIGN_IDENTITY='Apple Distribution' " \
                        "PROVISIONING_PROFILE_SPECIFIER='#{profile_uuid}'",
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        teamID:               DIST_TEAM_ID,
        provisioningProfiles: {
          BUNDLE_ID => profile_uuid
        }
      }
    )
  end

  # ─── TestFlight ─────────────────────────────────────────────────────────────
  lane :beta do
    build
    upload_to_testflight(
      app_identifier:                    BUNDLE_ID,
      skip_waiting_for_build_processing: true
    )
  end

  # ─── App Store ──────────────────────────────────────────────────────────────
  lane :release do
    build
    upload_to_app_store(
      app_identifier:    BUNDLE_ID,
      metadata_path:     "./fastlane/metadata",
      skip_screenshots:  true,
      submit_for_review: true,
      automatic_release: false,
      force:             true
    )
  end

end
